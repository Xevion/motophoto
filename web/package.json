{
	"name": "web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "bun@1.3.9",
	"scripts": {
		"preinstall": "node --eval \"if (process.env.npm_execpath && !/bun/.test(process.env.npm_execpath)) { console.error('\\nThis project requires bun. Run: bun install\\n'); process.exit(1) }\"",
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync; panda codegen",
		"codegen": "panda codegen",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint --cache --max-warnings 0 .",
		"lint:fix": "eslint --cache --fix .",
		"format": "biome format --write .",
		"format:check": "biome check --formatter-enabled=true --linter-enabled=false ."
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.3",
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^10.0.1",
		"@lucide/svelte": "^0.575.0",
		"@pandacss/dev": "^1.8.2",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/node": "^25.3.0",
		"@typescript-eslint/parser": "^8.56.0",
		"@xevion/svelte-adapter-bun": "^1.0.1",
		"@xevion/ts-eslint-extra": "^0.10.0",
		"eslint": "^10.0.1",
		"eslint-plugin-svelte": "^3.15.0",
		"globals": "^17.3.0",
		"svelte": "^5.51.0",
		"svelte-check": "^4.3.6",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.0",
		"vite": "^7.3.1",
		"vite-plugin-devtools-json": "^1.0.0"
	},
	"dependencies": {
		"@ark-ui/svelte": "^5.19.0",
		"@logtape/logtape": "^2.0.2",
		"date-fns": "^4.1.0",
		"photoswipe": "^5.4.4",
		"sveltekit-superforms": "^2.30.0",
		"zod": "^4.3.6"
	}
}
